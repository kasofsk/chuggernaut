# Multi-stage build with cargo-chef for cached dependency builds
FROM rust:1.88-bookworm AS chef
RUN cargo install cargo-chef
WORKDIR /build

FROM chef AS planner
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
RUN cargo chef prepare --recipe-path recipe.json

FROM chef AS builder
COPY --from=planner /build/recipe.json recipe.json
RUN cargo chef cook --release --recipe-path recipe.json -p chuggernaut-worker -p chuggernaut-channel
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
RUN cargo build --release -p chuggernaut-worker -p chuggernaut-channel

# Runner environment image — used by Forgejo Actions runner for job containers
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates jq curl nodejs bash unzip \
  && rm -rf /var/lib/apt/lists/*

# Install NATS CLI (used by workflow steps to fetch job data from KV)
RUN NATS_VER=$(curl -fsSL https://api.github.com/repos/nats-io/natscli/releases/latest | jq -r .tag_name) \
  && curl -fsSL "https://github.com/nats-io/natscli/releases/download/${NATS_VER}/nats-${NATS_VER#v}-linux-amd64.zip" -o /tmp/nats.zip \
  && unzip -j /tmp/nats.zip '*/nats' -d /usr/local/bin/ \
  && rm /tmp/nats.zip \
  && chmod +x /usr/local/bin/nats

# Claude Code installer requires bash; installs to ~/.local/bin/
RUN curl -fsSL https://claude.ai/install.sh | bash \
  && ln -sf /root/.local/bin/claude /usr/local/bin/claude

COPY --from=builder /build/target/release/chuggernaut-worker /usr/local/bin/chuggernaut-worker
COPY --from=builder /build/target/release/chuggernaut-channel /usr/local/bin/chuggernaut-channel
COPY action/mock-claude/mock-claude.sh /usr/local/bin/mock-claude
COPY action/mock-claude/mock-review.sh /usr/local/bin/mock-review
RUN chmod +x /usr/local/bin/mock-claude /usr/local/bin/mock-review

RUN git config --system user.email "chuggernaut@test.local" \
 && git config --system user.name "Chuggernaut Worker"
