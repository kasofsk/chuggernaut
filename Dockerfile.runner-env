# Multi-stage build: compile chuggernaut-worker for Linux, then package into slim image
FROM rust:1.88-bookworm AS builder

WORKDIR /build
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/

RUN cargo build --release -p chuggernaut-worker

# Runner environment image — used by Forgejo Actions runner for job containers
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates jq curl \
  && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/chuggernaut-worker /usr/local/bin/chuggernaut-worker
COPY action/mock-claude/mock-claude.sh /usr/local/bin/mock-claude

RUN git config --system user.email "chuggernaut@test.local" \
 && git config --system user.name "Chuggernaut Worker"
