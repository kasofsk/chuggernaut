# Flutter + Android development flavor of the runner environment image.
# Uses the same slim base as runner-env and copies the worker binary + SDKs
# from independent stages, so flutter/android layers stay cached even when
# the worker binary is rebuilt.
#
# Build: docker build -t chuggernaut-runner-env:flutter -f Dockerfile.runner-env.flutter .
# Register runner with label: "flutter:docker://chuggernaut-runner-env:flutter"
# Configure dispatcher: CHUGGERNAUT_RUNNER_LABEL_MAP='{"flutter":"flutter"}'

# --- Stage 1: download and prepare Flutter + Android SDKs (cached independently) ---
FROM debian:bookworm-slim AS flutter-sdk

RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates curl unzip openjdk-17-jdk-headless \
  && rm -rf /var/lib/apt/lists/*

# Flutter SDK
ENV FLUTTER_ROOT=/opt/flutter
ENV PATH="${FLUTTER_ROOT}/bin:${PATH}"
RUN git clone --depth 1 --branch stable https://github.com/flutter/flutter.git ${FLUTTER_ROOT} \
 && flutter precache --android \
 && flutter config --no-analytics

# Android SDK command-line tools
ENV ANDROID_HOME=/opt/android-sdk
ENV PATH="${ANDROID_HOME}/cmdline-tools/latest/bin:${ANDROID_HOME}/platform-tools:${PATH}"
RUN mkdir -p ${ANDROID_HOME}/cmdline-tools \
 && curl -fsSL https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip -o /tmp/cmdline.zip \
 && unzip -q /tmp/cmdline.zip -d ${ANDROID_HOME}/cmdline-tools \
 && mv ${ANDROID_HOME}/cmdline-tools/cmdline-tools ${ANDROID_HOME}/cmdline-tools/latest \
 && rm /tmp/cmdline.zip \
 && yes | sdkmanager --licenses > /dev/null 2>&1 \
 && sdkmanager "build-tools;34.0.0" "platforms;android-34" "platform-tools"

# --- Stage 2: final image from slim base, not runner-env ---
FROM debian:bookworm-slim

# System packages: runner-env basics + flutter build deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates jq curl nodejs bash unzip \
    clang cmake ninja-build pkg-config \
    openjdk-17-jdk-headless \
    libgtk-3-dev \
  && rm -rf /var/lib/apt/lists/*

# NATS CLI
RUN NATS_VER=$(curl -fsSL https://api.github.com/repos/nats-io/natscli/releases/latest | jq -r .tag_name) \
  && curl -fsSL "https://github.com/nats-io/natscli/releases/download/${NATS_VER}/nats-${NATS_VER#v}-linux-amd64.zip" -o /tmp/nats.zip \
  && unzip -j /tmp/nats.zip '*/nats' -d /usr/local/bin/ \
  && rm /tmp/nats.zip \
  && chmod +x /usr/local/bin/nats

# Claude Code
RUN curl -fsSL https://claude.ai/install.sh | bash \
  && ln -sf /root/.local/bin/claude /usr/local/bin/claude

# Worker binary — only this layer invalidates on worker rebuild
COPY --from=chuggernaut-runner-env:latest /usr/local/bin/chuggernaut-worker /usr/local/bin/chuggernaut-worker
COPY --from=chuggernaut-runner-env:latest /usr/local/bin/chuggernaut-channel /usr/local/bin/chuggernaut-channel
COPY action/mock-claude/mock-claude.sh /usr/local/bin/mock-claude
COPY action/mock-claude/mock-review.sh /usr/local/bin/mock-review
RUN chmod +x /usr/local/bin/mock-claude /usr/local/bin/mock-review

RUN git config --system user.email "chuggernaut@test.local" \
 && git config --system user.name "Chuggernaut Worker"

# Flutter + Android SDKs (cached independently)
COPY --from=flutter-sdk /opt/flutter /opt/flutter
COPY --from=flutter-sdk /opt/android-sdk /opt/android-sdk

ENV FLUTTER_ROOT=/opt/flutter
ENV ANDROID_HOME=/opt/android-sdk
ENV PATH="${FLUTTER_ROOT}/bin:${ANDROID_HOME}/cmdline-tools/latest/bin:${ANDROID_HOME}/platform-tools:${PATH}"

RUN flutter doctor
